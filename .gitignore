# ─── Dependencies ───
node_modules/

# ─── Personal project configs (never commit) ───
# Allowlist, not a per-client list — every real project config matches
# config/*.json and is excluded by default; only example.json ships. This way
# a brand-new client config can never slip through just because nobody
# remembered to add its filename here.
config/*.json
!config/example.json
carbium
carbium/

# ─── Archive (local only) ───
archive/

# ─── IDE / tool configs ───
.claude/
CLAUDE.md

# ─── Database & runtime files ───
*.db
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.db-wal
*.db-shm
seo-intel.db*
.extraction-progress.json

# ─── Reports output (generated, not source) ───
# Allowlist — everything under reports/ is generated client output by default
# (including nested subdirectories like reports/<client>-fixes/), except the
# handful of generator scripts that actually ship with the package.
reports/*
!reports/d3.v7.min.js
!reports/generate-html.js
!reports/generate-site-graph.js
!reports/gsc-loader.js

# ─── Crawl/session data ───
gsc/
.sessions/
.cache/
.tokens/

# ─── Environment ───
.env
.env.local

# ─── Internal dev docs (Obsidian vault, not for public repo) ───
PUBLISH.md
PUBLISHING.md
ROADMAP.md
BUGS.md
ARCHITECTURE.md
DASHBOARD_DOCTRINE.md
CLAUDE_CODE_BRIEF_*.md
*_BRIEF.md
GAP_INTEL_BRIEF.md
AGENT_HARNESS.md
SECURITY*.md
SECURITY-*.md
PRODUCT_STATUS.md
agent-task*.md
COMMANDS.md
seo-intel-promo/
scripts/*
!scripts/
!scripts/mock-crawl-test.js
.firecrawl/

# ─── Build artifacts ───
*.tgz
*.zip
*.bak
*.bak-*

# ─── OS ───
.DS_Store
Thumbs.db
